<header class="site-header" role="banner">
  <div class="container">
    <!-- Desktop header -->
    <div class="site-header-desktop" aria-label="Site header">
      <a class="brand" href="/">{{site.title}}</a>

      <div class="site-header-right">
        <nav class="site-nav-inline" aria-label="Pages">
          {{#nav.pages}}
            <a class="nav-link" href="/{{slug}}/">{{title}}</a>
          {{/nav.pages}}
        </nav>
        {{{global.scheme_toggle_html}}}
      </div>
    </div>

    <!-- Mobile header -->
    <div class="site-header-mobile" aria-label="Site header (mobile)">
      <a class="brand" href="/">{{site.title}}</a>

      <details class="mobile-menu">
        <summary class="mobile-menu-summary" aria-label="Menu">
          <span class="hamburger" aria-hidden="true"></span>
          <span class="mobile-menu-label">Menu</span>
        </summary>

        <div class="mobile-menu-panel">
          <nav class="site-nav-mobile" aria-label="Pages">
            {{#nav.pages}}
              <a class="nav-link" href="/{{slug}}/">{{title}}</a>
            {{/nav.pages}}
          </nav>
          <div class="mobile-menu-actions">
            {{{global.scheme_toggle_html}}}
          </div>
        </div>
      </details>
    </div>
  </div>
</header>
