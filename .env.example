# Server
PORT=3000
BASE_URL=http://localhost:3000

# Security (required in production)
APP_SECRET=change-me-to-a-long-random-string

# Unlock cookie TTL
UNLOCK_DAYS=30

# Set true in production behind HTTPS so cookies are marked Secure
COOKIE_SECURE=false

# Payments
# Options: alby_hub | lnbits
# Recommended/default: alby_hub
PAYMENTS_PROVIDER=alby_hub

# LNbits (hosted instance)
# Example: https://legend.lnbits.com
LNBITS_URL=
LNBITS_INVOICE_KEY=
LNBITS_READ_KEY=

# Alby Hub
# Example: nostr+walletconnect://<wallet-pubkey>?relay=wss://relay.getalby.com/v1&secret=<hex>
ALBY_HUB_URL=
